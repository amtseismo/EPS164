rt_time":"2026-03-21T01:18:44.504862Z"},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom ipywidgets import interact, FloatSlider","visibility":"hide","key":"pQJiBC4HTA"},{"type":"outputs","id":"lXwTqpLMhLkQfSn0jidRR","children":[],"visibility":"show","key":"hXKYgU8Sxy"}],"visibility":"show","key":"Ba0esLb4Jl"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Define the unit square.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"J9h4sdI7OF"}],"key":"bgWLBZz8if"}],"key":"EEzi8CDE3a"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T01:18:44.526596Z","start_time":"2026-03-21T01:18:44.514353Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def unit_square():\n    return np.array([\n        [0,0],\n        [1,0],\n        [1,1],\n        [0,1],\n        [0,0]\n    ])","key":"HlhuRbAY86"},{"type":"outputs","id":"tchUTME3F8yOqU3cQXslv","children":[],"key":"e4HrOePxER"}],"key":"NgPb1g8UXM"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Define strain and rotation tensor.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fnSmCTY1xo"}],"key":"bmA5PHaBAu"}],"key":"aa1PdJkRBI"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T01:18:44.533757Z","start_time":"2026-03-21T01:18:44.528013Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def build_tensors(exx=0, ezz=0, exz=0, omega=0):\n    # Symmetric strain tensor\n    E = np.array([\n        [exx, exz],\n        [exz, ezz]\n    ])\n    # Antisymmetric rotation tensor\n    W = np.array([\n        [0, -omega],\n        [omega, 0]\n    ])\n    I = np.eye(2)\n    F = I + E + W\n    return E, W, F","key":"pleOCA32sS"},{"type":"outputs","id":"MveAKVTiwOnqmk_ZsrMth","children":[],"key":"mS7UbM1IGM"}],"key":"dyjF9o7Zfd"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Apply Deformation","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"F0IZSIOK5z"}],"key":"eJpZYIQtlp"}],"key":"OBQkj6tXKm"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T01:18:44.540193Z","start_time":"2026-03-21T01:18:44.535782Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def deform(points, F):\n    return points @ F.T","key":"wWFaKPIZMH"},{"type":"outputs","id":"d9v4bIoYLazC3tWDIvAbb","children":[],"key":"gcqANHKrnH"}],"key":"qdOBXzetAh"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plot the deformation.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kOlUF3LjWb"}],"key":"mx7VaIJC70"}],"key":"CQYTkZAEcx"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T01:18:44.545562Z","start_time":"2026-03-21T01:18:44.540714Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def plot_deformation(exx=0, ezz=0, exz=0, omega=0):\n\n    pts = unit_square()\n\n    E, W, F = build_tensors(exx, ezz, exz, omega)\n\n    pts_strain = deform(pts, np.eye(2) + E)\n    pts_rot = deform(pts, np.eye(2) + W)\n    pts_total = deform(pts, F)\n\n    fig, ax = plt.subplots(figsize=(7,7))\n\n    ax.plot(pts[:,0], pts[:,1],'w--',linewidth=2,label='Undeformed')\n\n    ax.plot(pts_strain[:,0], pts_strain[:,1],linewidth=2,label='Strain')\n\n    ax.plot(pts_rot[:,0], pts_rot[:,1],linewidth=2,label='Rotation')\n\n    ax.plot(pts_total[:,0], pts_total[:,1],linewidth=3,label='Total')\n\n    ax.set_aspect('equal')\n\n    ax.grid(True,alpha=.3)\n\n    ax.set_xlabel(\"x\")\n    ax.set_ylabel(\"z\")\n\n    ax.set_title(\"Strain and Rotation Effects on a Unit Square\")\n\n    ax.legend()\n\n    plt.show()","key":"bsfpeHLYsy"},{"type":"outputs","id":"VBkO-VJ1zDvvbqvu5G8hE","children":[],"key":"Jl0N705TlF"}],"key":"uPJUujz2EQ"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T01:18:44.602001Z","start_time":"2026-03-21T01:18:44.545959Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"interact(\n    plot_deformation,\n\n    exx=FloatSlider(min=-0.5,max=0.5,step=0.01,value=0),\n    ezz=FloatSlider(min=-0.5,max=0.5,step=0.01,value=0),\n    exz=FloatSlider(min=-0.5,max=0.5,step=0.01,value=0),\n\n    omega=FloatSlider(min=-0.5,max=0.5,step=0.01,value=0)\n);","key":"byD0yg8bgl"},{"type":"outputs","id":"sCKtrBru_LoScpu8WgCKw","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"interactive(children=(FloatSlider(value=0.0, description='exx', max=0.5, min=-0.5, step=0.01), FloatSlider(val…","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"eeba825e57104e4bbbf320b2cd10b1f3\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"children":[],"key":"AZbe1HupeH"}],"key":"vl3ZJfjdA0"}],"key":"D2A2zvtArw"}],"key":"kkJNGwI8WE"},"references":{"cite":{"order":[],"data":{}}}}